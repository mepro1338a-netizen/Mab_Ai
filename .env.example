# ======================
# MAB.AI ENV CONFIG
# ======================

# OAuth Login (Google / Instagram / TikTok)
APP_BASE_URL=https://mabai-production.up.railway.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
OAUTH_STATE_SECRET=

# OpenAI - Chat, Coding, Content, fallback Images
OPENAI_API_KEY=
OPENAI_FREE_MODEL=gpt-4o-mini
OPENAI_PRO_MODEL=gpt-4o-mini
OPENAI_GRAND_MODEL=gpt-4.1-mini
OPENAI_ELITE_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Stability AI - optional image provider
# https://platform.stability.ai/
STABILITY_API_KEY=
STABILITY_IMAGE_MODEL=stable-image-core

# Replicate - optional video/music provider
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v1.6-standard
REPLICATE_MUSIC_MODEL=meta/musicgen

# fal.ai - optional video/music provider
# https://fal.ai/dashboard/keys
FAL_KEY=
FAL_VIDEO_ENDPOINT=
FAL_MUSIC_ENDPOINT=

# Which provider should be used?
# images: openai or stability
IMAGE_PROVIDER=openai
# video: replicate or fal
VIDEO_PROVIDER=replicate
# music: replicate or fal or openai_prompt
MUSIC_PROVIDER=replicate

# Stripe Checkout
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_GRAND=
STRIPE_PRICE_ELITE=
STRIPE_SUCCESS_URL=http://localhost:8501
STRIPE_CANCEL_URL=http://localhost:8501

# Optional email verification sender
# For now verification code is shown in app. Later connect SMTP/Resend.
RESEND_API_KEY=
EMAIL_FROM=verify@mab.ai

# Optional Suno-compatible custom song API wrapper
# Only use this if you have a legal/commercial API provider.
SUNO_API_URL=
SUNO_API_KEY=
