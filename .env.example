# ======================
# MAB.AI ENV CONFIG
# ======================

# Railway: PORT wird automatisch gesetzt
# DATA_DIR=/data  (Volume mount empfohlen)
# APP_BASE_URL=https://mabyte.de

# OAuth Login (Google / Instagram / TikTok)
# Plain URL only — no markdown [text](url) or brackets
# APP_BASE_URL=https://mabai-production.up.railway.app
APP_BASE_URL=https://mabyte.de
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — volle Redirect-URL (muss exakt in Google Console stehen)
# GOOGLE_OAUTH_REDIRECT_URI=https://mabyte.de/
# GOOGLE_OAUTH_REDIRECT_PATH=/oauth/google/callback
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
OAUTH_STATE_SECRET=

# OpenAI - Chat, Coding, Content, fallback Images
OPENAI_API_KEY=
OPENAI_FREE_MODEL=gpt-4o-mini
OPENAI_PRO_MODEL=gpt-4o-mini
OPENAI_GRAND_MODEL=gpt-4.1-mini
OPENAI_ELITE_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Stability AI - optional image provider
# https://platform.stability.ai/
STABILITY_API_KEY=
STABILITY_IMAGE_MODEL=stable-image-core

# Replicate - optional video/music provider
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v1.6-standard
# Alias (Railway): VIDEO_MODEL=kwaivgi/kling-v1.6-standard
REPLICATE_MUSIC_MODEL=meta/musicgen

# fal.ai - optional video/music provider
# https://fal.ai/dashboard/keys
FAL_KEY=
FAL_VIDEO_ENDPOINT=
FAL_MUSIC_ENDPOINT=

# Which provider should be used?
# images: openai or stability
IMAGE_PROVIDER=openai
# video: replicate or fal
VIDEO_PROVIDER=auto
REPLICATE_REELS_MODEL=
# music: replicate or fal or openai_prompt
MUSIC_PROVIDER=replicate

# Stripe Checkout
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_GRAND=
STRIPE_PRICE_ELITE=
# Optional fallback if APP_BASE_URL unset — do NOT use localhost on Railway
# STRIPE_SUCCESS_URL=https://mabai-production.up.railway.app

# Deprecated — api-sports.io wird nicht mehr genutzt (keine Fixture-/Odds-Calls)
# FOOTBALL_API_KEY=

# football-data.org v4 — Free-Tier Quelle für Spielplan + Tabellen (erforderlich)
# Key unter https://www.football-data.org/client/register holen
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_TIMEOUT=20
FOOTBALL_DATA_CACHE_TTL=21600
FOOTBALL_DEFAULT_SEASON=2025

# Football AI FastAPI (Railway zweiter Service — railway.api.toml)
# API-Service: FOOTBALL_DATA_API_KEY + API_CORS_ORIGINS (Streamlit-Domain)
# Streamlit-Service: FOOTBALL_AI_API_URL = öffentliche API-URL
FOOTBALL_AI_API_URL=
FOOTBALL_AI_CACHE_TTL=900
API_CORS_ORIGINS=https://mabai-production.up.railway.app,https://mabyte.de

# Deprecated api-sports.io (nicht mehr für Fixtures/Odds)
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_CACHE_TTL=300
FOOTBALL_API_LIVE_CACHE_TTL=60
FOOTBALL_API_TIMEOUT=20

# Optional email verification sender
# For now verification code is shown in app. Later connect SMTP/Resend.
RESEND_API_KEY=
EMAIL_FROM=verify@mab.ai

# Optional Suno-compatible custom song API wrapper
# Only use this if you have a legal/commercial API provider.
SUNO_API_URL=
SUNO_API_KEY=
